{
  "name": "xenia-linux-manager",
  "private": true,
  "version": "0.1.0",
  "description": "Xenia Xbox 360 Emulator Manager for Linux",
  "author": "Sergen",
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "tsc -b && electron-vite build",
    "preview": "electron-vite preview",
    "lint": "eslint .",
    "test": "vitest",
    "test:electron": "vitest run --config vitest.electron.config.ts",
    "smoke": "xvfb-run -a electron-vite preview -- --smoke",
    "build:sidecar": "cd core && cargo build --release --bin xlm-core",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build:sidecar && npm run build && electron-builder --linux AppImage"
  },
  "dependencies": {
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/oswald": "^5.2.8",
    "@fontsource/titillium-web": "^5.2.8",
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.9",
    "lucide-react": "^1.20.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.6.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "electron-vite": "^6.0.0-beta.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^26.1.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^8.0.0",
    "vitest": "^3.2.6"
  },
  "build": {
    "appId": "com.xenia-linux-manager.app",
    "productName": "Xenia Manager for Linux",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "core/target/release/xlm-core",
        "to": "xlm-core"
      }
    ],
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Game",
      "icon": "build/icon.png",
      "artifactName": "${name}-${version}.${ext}"
    },
    "asar": true,
    "publish": [
      {
        "provider": "github",
        "owner": "sergen213",
        "repo": "xenia-linux-manager"
      }
    ]
  }
}
