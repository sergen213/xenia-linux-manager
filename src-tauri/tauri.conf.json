{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Xenia Manager for Linux",
  "version": "0.1.0",
  "identifier": "com.xenia-linux-manager.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Xenia Manager for Linux",
        "width": 1100,
        "height": 700,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ],
    "category": "Game",
    "shortDescription": "Manage Xenia Xbox 360 emulator installations, game libraries, patches, profiles, and saves on Linux",
    "longDescription": "Xenia Manager for Linux is a native desktop application for managing the Xenia Xbox 360 emulator on Linux. It handles emulator installation and updates, game library scanning and organization, patch and profile management, save portability, and launch configuration — all from a single AppImage.",
    "createUpdaterArtifacts": true,
    "linux": {
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "",
      "endpoints": [
        "https://github.com/xenialinuxmanager/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
